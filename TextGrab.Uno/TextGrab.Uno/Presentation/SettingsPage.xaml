<Page x:Class="TextGrab.Presentation.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      NavigationCacheMode="Required">

  <NavigationView x:Name="SettingsNavView"
                  uen:Region.Attached="true"
                  IsBackButtonVisible="Collapsed"
                  PaneDisplayMode="LeftCompact"
                  IsSettingsVisible="False">

    <NavigationView.MenuItems>
      <NavigationViewItem uen:Region.Name="GeneralSettings"
                          Content="General">
        <NavigationViewItem.Icon>
          <SymbolIcon Symbol="Home" />
        </NavigationViewItem.Icon>
      </NavigationViewItem>
      <NavigationViewItem uen:Region.Name="FullscreenGrabSettings"
                          Content="Fullscreen Grab">
        <NavigationViewItem.Icon>
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xEA3A;" />
        </NavigationViewItem.Icon>
      </NavigationViewItem>
      <NavigationViewItem uen:Region.Name="LanguageSettings"
                          Content="Languages">
        <NavigationViewItem.Icon>
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xF2B7;" />
        </NavigationViewItem.Icon>
      </NavigationViewItem>
      <NavigationViewItem uen:Region.Name="KeysSettings"
                          Content="Keyboard Shortcuts">
        <NavigationViewItem.Icon>
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE765;" />
        </NavigationViewItem.Icon>
      </NavigationViewItem>
      <NavigationViewItem uen:Region.Name="TesseractSettings"
                          Content="Tesseract">
        <NavigationViewItem.Icon>
          <SymbolIcon Symbol="Globe" />
        </NavigationViewItem.Icon>
      </NavigationViewItem>
    </NavigationView.MenuItems>

    <NavigationView.FooterMenuItems>
      <NavigationViewItem uen:Region.Name="DangerSettings"
                          Content="Danger">
        <NavigationViewItem.Icon>
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7BA;" />
        </NavigationViewItem.Icon>
      </NavigationViewItem>
    </NavigationView.FooterMenuItems>

    <Grid uen:Region.Attached="true" uen:Region.Navigator="Visibility">
      <Grid uen:Region.Name="GeneralSettings" />
      <Grid uen:Region.Name="FullscreenGrabSettings" />
      <Grid uen:Region.Name="LanguageSettings" />
      <Grid uen:Region.Name="KeysSettings" />
      <Grid uen:Region.Name="TesseractSettings" />
      <Grid uen:Region.Name="DangerSettings" />
    </Grid>

  </NavigationView>
</Page>
