<Page x:Class="TextGrab.Presentation.FullscreenGrabPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      NavigationCacheMode="Disabled"
      KeyDown="Page_KeyDown">

  <Page.KeyboardAccelerators>
    <KeyboardAccelerator Key="Escape" Invoked="EscAccelerator_Invoked" />
  </Page.KeyboardAccelerators>

  <Grid Background="Black">
    <!-- Screen capture image fills entire page -->
    <Image x:Name="BackgroundImage"
           Stretch="UniformToFill"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch" />

    <!-- Semi-transparent overlay Canvas for region selection -->
    <Canvas x:Name="SelectionCanvas"
            Background="#60000000"
            PointerPressed="Canvas_PointerPressed"
            PointerMoved="Canvas_PointerMoved"
            PointerReleased="Canvas_PointerReleased">

      <!-- Selection rectangle -->
      <Border x:Name="SelectionBorder"
              BorderBrush="#308E98"
              BorderThickness="2"
              Background="#20FFFFFF"
              Visibility="Collapsed" />

      <Canvas.ContextFlyout>
        <MenuFlyout>
          <ToggleMenuFlyoutItem x:Name="SingleLineCtxItem" Text="Single Line Mode" />
          <ToggleMenuFlyoutItem x:Name="TableCtxItem" Text="Table Mode" />
          <ToggleMenuFlyoutItem x:Name="FreezeCtxItem" Text="Freeze (F)" Click="Freeze_Click" />
          <ToggleMenuFlyoutItem x:Name="SendToEtwCtxItem" Text="Send to Edit Text" />
          <MenuFlyoutSeparator />
          <MenuFlyoutItem Text="Settings" Click="Settings_Click" />
          <MenuFlyoutItem Text="Cancel" Click="Cancel_Click" />
        </MenuFlyout>
      </Canvas.ContextFlyout>
    </Canvas>

    <!-- Floating toolbar (top center, dark translucent) -->
    <Border x:Name="FloatingToolbar"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,12,0,0"
            Padding="12,6"
            CornerRadius="8"
            Background="#E0202020"
            ManipulationMode="TranslateX,TranslateY"
            Translation="0,0,32">
      <Border.RenderTransform>
        <TranslateTransform x:Name="ToolbarTranslate" />
      </Border.RenderTransform>
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <FontIcon Glyph="&#xE76F;"
                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  Foreground="#80FFFFFF"
                  FontSize="14"
                  VerticalAlignment="Center"
                  Margin="0,0,4,0"
                  IsHitTestVisible="False"
                  ToolTipService.ToolTip="Drag to move toolbar" />
        <ComboBox x:Name="LanguagesComboBox"
                  MinWidth="150"
                  PlaceholderText="Language" />

        <Border Width="1" Background="#40FFFFFF" Margin="4,2" />

        <RadioButton x:Name="NormalModeRadio" Content="Standard" IsChecked="True"
                     GroupName="GrabMode" Foreground="White" MinWidth="0" Padding="4,0" />
        <RadioButton x:Name="SingleLineModeRadio" Content="Single Line"
                     GroupName="GrabMode" Foreground="White" MinWidth="0" Padding="4,0" />
        <RadioButton x:Name="TableModeRadio" Content="Table"
                     GroupName="GrabMode" Foreground="White" MinWidth="0" Padding="4,0" />

        <Border Width="1" Background="#40FFFFFF" Margin="4,2" />

        <ToggleButton x:Name="FreezeToggle" Content="&#xE786;"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      ToolTipService.ToolTip="Freeze (F) — re-capture without overlay"
                      Click="Freeze_Click" />

        <ToggleButton x:Name="SendToEtwToggle" Content="&#xE8A7;"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      ToolTipService.ToolTip="Send to Edit Text (E)" />

        <Button Content="&#xE713;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="Settings"
                Click="Settings_Click" />

        <Button Content="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="Cancel (Esc)"
                Click="Cancel_Click" />
      </StackPanel>
    </Border>

    <!-- Status bar (bottom center, dark translucent) -->
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,12"
            Padding="16,8"
            CornerRadius="8"
            Background="#E0202020">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock x:Name="StatusText"
                   Text="Draw a rectangle to capture text, or press Esc to cancel"
                   Foreground="White"
                   Style="{StaticResource BodyMedium}" />
        <ProgressRing x:Name="BusyRing" IsActive="False"
                      Width="16" Height="16" />
      </StackPanel>
    </Border>

    <!-- Non-Windows fallback -->
    <StackPanel x:Name="FallbackPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="Collapsed">
      <TextBlock Text="Screen capture requires Windows Desktop."
                 Style="{StaticResource TitleMedium}"
                 Foreground="White"
                 HorizontalAlignment="Center" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
        <Button Content="OCR from File" Click="OcrFromFile_Click" />
        <Button Content="OCR from Clipboard" Click="OcrFromClipboard_Click" />
        <Button Content="Back" Click="Cancel_Click" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Page>
